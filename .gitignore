# --- Root .gitignore for Catharsis Wellness Website ---

# Dependency directories
node_modules/
backend/venv/
backend/env/
.venv/
env/
venv/
ENV/

# Python/Django
**/__pycache__/
*.py[cod]
*$py.class
backend/db.sqlite3
backend/db.sqlite3-journal
backend/local_settings.py
backend/wellness_api/migrations/__init__.py
!backend/wellness_api/migrations/

# Next.js
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel

# Environment variables (Sensitive data)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
backend/.env
frontend/.env
frontend/.env.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# IDE & OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
frontend/coverage/

# Typescript
frontend/*.tsbuildinfo
frontend/next-env.d.ts
